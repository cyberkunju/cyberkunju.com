---
import Aurora from '../components/Aurora.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import JsonLd from '../components/JsonLd.astro';
import SEO from '../components/SEO.astro';
import SpeculationRules from '../components/SpeculationRules.astro';
import { site } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: Date;
  modifiedTime?: Date;
  jsonLdExtra?: Record<string, unknown>[];
}

const { title, description, image, type, noindex, publishedTime, modifiedTime, jsonLdExtra } =
  Astro.props;
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* No-flash theme + font: apply saved preferences before first paint. */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') document.documentElement.classList.add(t);
        } catch {}
      })();
    </script>
    {/* Brand typeface: Pally (Fontshare). System stack is the swap fallback.
        Self-host later from a network that can reach cdn.fontshare.com. */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=pally@400,500,700&display=swap"
    />
    {/* Display face for the wordmark: Oxanium (techno / sci-fi). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Oxanium:wght@600;700;800&display=swap"
    />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />
    <JsonLd extra={jsonLdExtra} />
    <SpeculationRules />
  </head>

  <body>
    <Aurora />
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" class="container">
      <slot />
    </main>
    <Footer />

    {/* Register the service worker for instant repeat visits + offline shell. */}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
