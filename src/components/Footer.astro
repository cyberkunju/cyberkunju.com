---
import { site } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p>© {year} {site.name}</p>
    <nav class="cluster" aria-label="Social">
      {
        site.social.map((s) => (
          <a href={s.href} rel="me noopener" target="_blank" data-no-prerender>
            {s.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
