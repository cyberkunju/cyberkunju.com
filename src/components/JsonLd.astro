---
import { site } from '../config/site';

interface Props {
  /** Optional additional structured-data objects to emit alongside Person + WebSite. */
  extra?: Record<string, unknown>[];
}

const { extra = [] } = Astro.props;

const person = {
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  alternateName: site.handle,
  jobTitle: site.jobTitle,
  email: `mailto:${site.email}`,
  url: site.url,
  sameAs: site.social.filter((s) => s.sameAs).map((s) => s.href),
};

const website = {
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  url: site.url,
  name: site.name,
  description: site.description,
  inLanguage: site.locale,
  publisher: { '@id': `${site.url}/#person` },
};

const graph = {
  '@context': 'https://schema.org',
  '@graph': [person, website, ...extra],
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} is:inline />
