---
/**
 * Aurora — a subtle, ever-drifting mesh of muted red + green.
 *
 * Three heavily-blurred blobs are retargeted to new random positions/scales on
 * an interval (the "engine"); long CSS transitions tween the motion on the GPU,
 * so it reads as continuous organic drift that never repeats. Frozen when the
 * visitor prefers reduced motion. Purely decorative (aria-hidden).
 *
 * Place inside a `position: relative; overflow: hidden` container; site content
 * should sit in a layer above it.
 */
---

<div class="aurora" aria-hidden="true">
  <span class="aurora__blob a"></span>
  <span class="aurora__blob b"></span>
  <span class="aurora__blob c"></span>
</div>

<style>
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .aurora__blob {
    position: absolute;
    width: 62%;
    aspect-ratio: 1;
    border-radius: 50%;
    filter: blur(72px);
    transform: translate(-50%, -50%) translate(var(--tx, 0%), var(--ty, 0%)) scale(var(--s, 1));
    transition: transform 9s cubic-bezier(0.37, 0, 0.63, 1);
    will-change: transform;
  }
  .aurora__blob.a {
    left: 18%;
    top: 22%;
    background: radial-gradient(circle, rgba(197, 84, 72, 0.55), transparent 68%);
  }
  .aurora__blob.b {
    left: 68%;
    top: 52%;
    background: radial-gradient(circle, rgba(84, 162, 118, 0.5), transparent 68%);
  }
  .aurora__blob.c {
    left: 38%;
    top: 82%;
    background: radial-gradient(circle, rgba(150, 74, 92, 0.45), transparent 70%);
  }
  @media (prefers-reduced-motion: reduce) {
    .aurora__blob { transition: none; }
  }
</style>

<script is:inline>
  (() => {
    if (window.__aurora) return;
    window.__aurora = true;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const rand = (min, max) => (Math.random() * (max - min) + min).toFixed(2);
    function tick() {
      document.querySelectorAll('.aurora__blob').forEach((b) => {
        b.style.setProperty('--tx', rand(-30, 30) + '%');
        b.style.setProperty('--ty', rand(-30, 30) + '%');
        b.style.setProperty('--s', rand(0.8, 1.45));
      });
    }
    tick();
    if (!reduce) setInterval(tick, 6000);
  })();
</script>
