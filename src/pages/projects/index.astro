---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort((a, b) => {
  const ao = a.data.order ?? Number.MAX_SAFE_INTEGER;
  const bo = b.data.order ?? Number.MAX_SAFE_INTEGER;
  if (ao !== bo) return ao - bo;
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<BaseLayout
  title="Work"
  description="Selected projects and the engineering behind them."
>
  <section class="stack" style="--flow: var(--space-lg); padding-block: var(--space-2xl) var(--space-xl);">
    <div class="stack" style="--flow: var(--space-xs); max-width: var(--container-narrow);">
      <h1>Work</h1>
      <p class="muted">Projects, systems, and the decisions behind them.</p>
    </div>

    <ul role="list" class="grid-cards cv-auto">
      {
        projects.map((p) => (
          <li>
            <a class="card" href={`/projects/${p.id}`}>
              <span class="eyebrow">{p.data.role}</span>
              <h3>{p.data.title}</h3>
              <p class="muted">{p.data.summary}</p>
              <span class="cluster" style="margin-block-start: var(--space-xs);">
                {p.data.tags.slice(0, 5).map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
