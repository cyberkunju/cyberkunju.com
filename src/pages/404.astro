---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" noindex>
  <section
    class="stack"
    style="--flow: var(--space-md); text-align: center; padding-block: var(--space-3xl);"
  >
    <p class="eyebrow">404</p>
    <h1>This page took a wrong turn</h1>
    <p class="muted">The page you're looking for doesn't exist or has moved.</p>
    <p><a class="button" href="/">Back home</a></p>
  </section>
</BaseLayout>
