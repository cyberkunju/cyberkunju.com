---
// Brand Lab — a dev-only visual tuner for the wordmark treatment.
// Lives under /design/* so it is auto-excluded from the sitemap; also noindex.
// Standalone (no BaseLayout) so its interactive JS never touches the real,
// zero-JS site. Tweak every knob live, then copy the generated CSS (or JSON
// config) back into `.brand` in src/styles/base.css.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Brand Lab — wordmark tuner</title>
  </head>
  <body>
    <div id="app">
      <section id="stage" aria-label="Preview">
        <div id="stageInner">
          <iframe id="frame" src="/" title="Live site preview"></iframe>
        </div>
        <div id="stageBar">
          <span class="hint">Live homepage — tweaks apply to the real wordmark on the real top bar &amp; shape.</span>
          <label>Zoom <input type="range" data-k="zoom" min="1" max="4" step="0.1" /></label>
          <button id="reloadFrame" type="button">Reload</button>
        </div>
      </section>
      <aside id="panel">
        <h1>Brand Lab</h1>
        <div id="controls"></div>
        <div id="out">
          <div class="outHead">
            <strong>Generated CSS</strong>
            <span>
              <button id="copyCss" type="button">Copy CSS</button>
              <button id="copyJson" type="button">Copy JSON</button>
            </span>
          </div>
          <textarea id="css" readonly spellcheck="false"></textarea>
          <div class="outHead">
            <strong>Import JSON config</strong>
            <span>
              <button id="importJson" type="button">Apply</button>
              <button id="reset" type="button">Reset</button>
            </span>
          </div>
          <textarea id="jsonIn" spellcheck="false" placeholder="Paste a config JSON here and press Apply"></textarea>
        </div>
      </aside>
    </div>
    <style is:global>
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body {
        font: 13px/1.4 ui-sans-serif, system-ui, sans-serif;
        color: #e6e6e6;
        background: #0c0c0e;
      }
      #app { display: grid; grid-template-columns: 1fr 400px; height: 100vh; }
      #stage {
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        background: #151517;
      }
      #stageInner {
        flex: 1;
        overflow: hidden;
        background: #000;
      }
      #frame {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
        background: #000;
        transform-origin: top left;
      }
      #stageBar .hint { color: #7a7a82; margin-right: auto; }
      #stageBar {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
        padding: 8px 12px;
        background: #0c0c0e;
        border-top: 1px solid #26262a;
      }
      #stageBar label { display: inline-flex; gap: 6px; align-items: center; color: #b9b9c0; }
      #panel {
        overflow-y: auto;
        padding: 14px 16px 40px;
        background: #101012;
        border-left: 1px solid #26262a;
      }
      #panel h1 { font-size: 15px; margin: 4px 0 12px; letter-spacing: 0.02em; }
      .grp { border: 1px solid #26262a; border-radius: 8px; margin-bottom: 10px; }
      .grp > summary {
        cursor: pointer;
        padding: 8px 10px;
        font-weight: 600;
        color: #f0f0f2;
        list-style: none;
        user-select: none;
      }
      .grp > summary::-webkit-details-marker { display: none; }
      .grp[open] > summary { border-bottom: 1px solid #26262a; }
      .fields { padding: 8px 10px; display: grid; gap: 8px; }
      .row { display: grid; grid-template-columns: 116px 1fr 44px; gap: 8px; align-items: center; }
      .row > label { color: #a9a9b0; }
      .row input[type="range"] { width: 100%; }
      .row .val { text-align: right; color: #8a8a92; font-variant-numeric: tabular-nums; }
      input[type="text"], select, textarea, input[type="color"] {
        background: #1a1a1e;
        color: #e6e6e6;
        border: 1px solid #33333a;
        border-radius: 6px;
        padding: 4px 6px;
        font: inherit;
      }
      input[type="color"] { padding: 0; height: 26px; width: 44px; }
      .stops { display: grid; gap: 6px; }
      .stop { display: grid; grid-template-columns: 44px 1fr 40px 30px; gap: 6px; align-items: center; }
      .stop .val { text-align: right; color: #8a8a92; }
      .stopbtns { display: flex; gap: 6px; }
      button {
        background: #232329;
        color: #e6e6e6;
        border: 1px solid #3a3a42;
        border-radius: 6px;
        padding: 4px 10px;
        cursor: pointer;
        font: inherit;
      }
      button:hover { background: #2d2d35; }
      button.mini { padding: 2px 8px; }
      #out { margin-top: 14px; }
      .outHead { display: flex; justify-content: space-between; align-items: center; margin: 10px 0 4px; }
      textarea { width: 100%; min-height: 120px; resize: vertical; font-family: ui-monospace, monospace; font-size: 12px; }
      #jsonIn { min-height: 60px; }
    </style>

    <script is:inline>
      const DEFAULTS = {
        cellColor: "#ce2a21", cellAlpha: 1, styleWordmark: false,
        text: "CYBERKUNJU", font: "oxanium", size: 44, weight: 700, tracking: 0.08,
        transform: "uppercase", opacity: 1,
        fillMode: "gradient", solid: "#0a0a0a", gradAngle: 180,
        stops: [
          { c: "#ff5636", p: 0, a: 1 }, { c: "#3a100c", p: 8, a: 1 },
          { c: "#060203", p: 30, a: 1 }, { c: "#000000", p: 60, a: 1 },
          { c: "#2a0c08", p: 100, a: 1 },
        ],
        strokeW: 0, strokeC: "#ff5636", strokeA: 0.6,
        extDepth: 0, extAngle: 135, extStep: 1, extC: "#000000", extA: 0.5,
        embOn: true, hiC: "#ff8a6b", hiA: 0.5, hiX: 0, hiY: -0.5, hiBlur: 0.4,
        loC: "#000000", loA: 0.7, loX: 0, loY: 1, loBlur: 1.5,
        glowC: "#e5352b", glowA: 0.32, glowBlur: 7, glowLayers: 1,
        corner: 0.3,
        sheenOn: false, sheenC: "#ffffff", sheenA: 0.5, sheenW: 16, sheenAngle: 100, sheenSpeed: 8,
        backdrop: "aurora", backdropColor: "#8f3227", zoom: 1,
      };
      const FIELDS = [
        ["Logo Cell — poly behind the wordmark", [
          ["cellColor", "Fill color", "color"],
          ["cellAlpha", "Fill opacity", "range", { min: 0, max: 1, step: 0.01 }],
        ]],
        ["Text", [
          ["styleWordmark", "Style wordmark text (off = image logo)", "check"],
          ["text", "Text", "text"],
          ["font", "Font", "select", { opts: [["oxanium", "Oxanium"], ["chakra", "Chakra Petch"], ["quantico", "Quantico"], ["orbitron", "Orbitron"], ["rajdhani", "Rajdhani"], ["syncopate", "Syncopate"], ["audiowide", "Audiowide"], ["michroma", "Michroma"], ["aldrich", "Aldrich"], ["sans", "Pally"], ["mono", "Mono"], ["serif", "Serif"]] }],
          ["size", "Size", "range", { min: 12, max: 120, step: 1, unit: "px" }],
          ["weight", "Weight", "range", { min: 100, max: 900, step: 100 }],
          ["tracking", "Letter-spacing", "range", { min: -0.05, max: 0.5, step: 0.005, unit: "em" }],
          ["transform", "Case", "select", { opts: [["uppercase", "UPPER"], ["none", "none"], ["lowercase", "lower"], ["capitalize", "Cap"]] }],
          ["opacity", "Opacity", "range", { min: 0, max: 1, step: 0.01 }],
        ]],
        ["Fill", [
          ["fillMode", "Mode", "select", { opts: [["solid", "Solid"], ["gradient", "Gradient"], ["plasma", "Plasma (accent)"]] }],
          ["solid", "Solid color", "color"],
          ["gradAngle", "Gradient angle", "range", { min: 0, max: 360, step: 1, unit: "deg" }],
        ]],
        ["Stroke", [
          ["strokeW", "Width", "range", { min: 0, max: 6, step: 0.1, unit: "px" }],
          ["strokeC", "Color", "color"],
          ["strokeA", "Opacity", "range", { min: 0, max: 1, step: 0.01 }],
        ]],
        ["3D Extrude", [
          ["extDepth", "Depth (layers)", "range", { min: 0, max: 20, step: 1 }],
          ["extAngle", "Direction", "range", { min: 0, max: 360, step: 1, unit: "deg" }],
          ["extStep", "Step", "range", { min: 0.5, max: 4, step: 0.1, unit: "px" }],
          ["extC", "Color", "color"],
          ["extA", "Opacity", "range", { min: 0, max: 1, step: 0.01 }],
        ]],
        ["Emboss / Bevel", [
          ["embOn", "Enabled", "check"],
          ["hiC", "Highlight color", "color"],
          ["hiA", "Highlight opacity", "range", { min: 0, max: 1, step: 0.01 }],
          ["hiX", "Highlight X", "range", { min: -4, max: 4, step: 0.5, unit: "px" }],
          ["hiY", "Highlight Y", "range", { min: -4, max: 4, step: 0.5, unit: "px" }],
          ["hiBlur", "Highlight blur", "range", { min: 0, max: 6, step: 0.1, unit: "px" }],
          ["loC", "Shadow color", "color"],
          ["loA", "Shadow opacity", "range", { min: 0, max: 1, step: 0.01 }],
          ["loX", "Shadow X", "range", { min: -4, max: 4, step: 0.5, unit: "px" }],
          ["loY", "Shadow Y", "range", { min: -4, max: 4, step: 0.5, unit: "px" }],
          ["loBlur", "Shadow blur", "range", { min: 0, max: 8, step: 0.1, unit: "px" }],
        ]],
        ["Outer Glow", [
          ["glowC", "Color", "color"],
          ["glowA", "Opacity", "range", { min: 0, max: 1, step: 0.01 }],
          ["glowBlur", "Blur", "range", { min: 0, max: 30, step: 0.5, unit: "px" }],
          ["glowLayers", "Intensity (layers)", "range", { min: 0, max: 4, step: 1 }],
        ]],
        ["Softness", [
          ["corner", "Corner rounding blur", "range", { min: 0, max: 2, step: 0.05, unit: "px" }],
        ]],
        ["Animated Sheen", [
          ["sheenOn", "Enabled", "check"],
          ["sheenC", "Color", "color"],
          ["sheenA", "Opacity", "range", { min: 0, max: 1, step: 0.01 }],
          ["sheenW", "Band width", "range", { min: 2, max: 40, step: 1, unit: "%" }],
          ["sheenAngle", "Angle", "range", { min: 0, max: 360, step: 1, unit: "deg" }],
          ["sheenSpeed", "Cycle", "range", { min: 1, max: 15, step: 0.5, unit: "s" }],
        ]],
      ];
      const PLASMA = "linear-gradient(115deg, #9e1015, #e5241d, #ff5636)";

      let cfg = load();
      const $ = (s) => document.querySelector(s);

      function load() {
        try {
          const s = JSON.parse(localStorage.getItem("brandlab") || "null");
          if (s) return Object.assign(structuredClone(DEFAULTS), s);
        } catch {}
        return structuredClone(DEFAULTS);
      }
      function save() { localStorage.setItem("brandlab", JSON.stringify(cfg)); }

      function hexA(hex, a) {
        const h = hex.replace("#", "");
        const n = h.length === 3 ? h.split("").map((c) => c + c).join("") : h;
        const r = parseInt(n.slice(0, 2), 16), g = parseInt(n.slice(2, 4), 16), b = parseInt(n.slice(4, 6), 16);
        return `rgba(${r}, ${g}, ${b}, ${+(+a).toFixed(2)})`;
      }
      const rad = (d) => (d * Math.PI) / 180;
      const r2 = (n) => +(+n).toFixed(2);

      const FAM = {
        oxanium: '"Oxanium", sans-serif',
        chakra: '"Chakra Petch", sans-serif',
        quantico: '"Quantico", sans-serif',
        orbitron: '"Orbitron", sans-serif',
        rajdhani: '"Rajdhani", sans-serif',
        syncopate: '"Syncopate", sans-serif',
        audiowide: '"Audiowide", cursive',
        michroma: '"Michroma", sans-serif',
        aldrich: '"Aldrich", sans-serif',
        mono: 'ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace',
        sans: '"Pally", ui-sans-serif, system-ui, -apple-system, sans-serif',
        serif: 'Georgia, "Times New Roman", serif',
      };
      // Google Fonts families to load into the framed site when picked.
      const GFONT = {
        oxanium: "Oxanium:wght@500;600;700;800",
        chakra: "Chakra+Petch:wght@500;600;700",
        quantico: "Quantico:wght@700",
        orbitron: "Orbitron:wght@600;700;800;900",
        rajdhani: "Rajdhani:wght@600;700",
        syncopate: "Syncopate:wght@700",
        audiowide: "Audiowide",
        michroma: "Michroma",
        aldrich: "Aldrich",
      };

      function fillString() {
        if (cfg.fillMode === "plasma") return PLASMA;
        const stops = [...cfg.stops]
          .sort((a, b) => a.p - b.p)
          .map((s) => `${hexA(s.c, s.a)} ${r2(s.p)}%`)
          .join(", ");
        return `linear-gradient(${cfg.gradAngle}deg, ${stops})`;
      }

      function compute() {
        const useClip = cfg.fillMode !== "solid" || cfg.sheenOn;
        const d = [];
        d.push(`font-family: ${FAM[cfg.font] || FAM.mono}`);
        d.push(`font-size: ${cfg.size}px`);
        d.push(`font-weight: ${cfg.weight}`);
        d.push(`letter-spacing: ${cfg.tracking}em`);
        d.push(`text-transform: ${cfg.transform}`);
        d.push(`opacity: ${cfg.opacity}`);
        if (cfg.strokeW > 0) d.push(`-webkit-text-stroke: ${cfg.strokeW}px ${hexA(cfg.strokeC, cfg.strokeA)}`);

        // Depth layers, engine chosen by fill mode.
        const ext = [];
        for (let i = 1; i <= cfg.extDepth; i++) {
          const dx = r2(Math.cos(rad(cfg.extAngle)) * i * cfg.extStep);
          const dy = r2(Math.sin(rad(cfg.extAngle)) * i * cfg.extStep);
          const a = r2(cfg.extA * (1 - (i - 1) / (cfg.extDepth + 1)));
          ext.push({ dx, dy, rgba: hexA(cfg.extC, a) });
        }
        const glow = [];
        for (let i = 0; i < cfg.glowLayers; i++) glow.push(`drop-shadow(0 0 ${cfg.glowBlur}px ${hexA(cfg.glowC, cfg.glowA)})`);
        const blur = cfg.corner > 0 ? [`blur(${cfg.corner}px)`] : [];

        if (useClip) {
          const fill = fillString();
          let bg = fill;
          if (cfg.sheenOn) {
            const lo = r2(50 - cfg.sheenW / 2), hi = r2(50 + cfg.sheenW / 2);
            const sheen = `linear-gradient(${cfg.sheenAngle}deg, transparent ${lo}%, ${hexA(cfg.sheenC, cfg.sheenA)} 50%, transparent ${hi}%)`;
            bg = `${sheen}, ${fill}`;
          }
          d.push(`background: ${bg}`);
          if (cfg.sheenOn) {
            d.push(`background-size: 260% 100%, 100% 100%`);
            d.push(`background-repeat: no-repeat`);
            d.push(`background-position: 160% 0, 0 0`);
            d.push(`animation: brandlabSheen ${cfg.sheenSpeed}s linear infinite`);
          }
          d.push(`-webkit-background-clip: text`);
          d.push(`background-clip: text`);
          d.push(`-webkit-text-fill-color: transparent`);
          d.push(`color: transparent`);
          const f = [...blur];
          for (const e of ext) f.push(`drop-shadow(${e.dx}px ${e.dy}px 0 ${e.rgba})`);
          if (cfg.embOn) {
            f.push(`drop-shadow(${cfg.hiX}px ${cfg.hiY}px ${cfg.hiBlur}px ${hexA(cfg.hiC, cfg.hiA)})`);
            f.push(`drop-shadow(${cfg.loX}px ${cfg.loY}px ${cfg.loBlur}px ${hexA(cfg.loC, cfg.loA)})`);
          }
          f.push(...glow);
          if (f.length) d.push(`filter: ${f.join(" ")}`);
        } else {
          d.push(`color: ${cfg.solid}`);
          const ts = [];
          if (cfg.embOn) {
            ts.push(`${cfg.hiX}px ${cfg.hiY}px ${cfg.hiBlur}px ${hexA(cfg.hiC, cfg.hiA)}`);
            ts.push(`${cfg.loX}px ${cfg.loY}px ${cfg.loBlur}px ${hexA(cfg.loC, cfg.loA)}`);
          }
          for (const e of ext) ts.push(`${e.dx}px ${e.dy}px 0 ${e.rgba}`);
          if (ts.length) d.push(`text-shadow: ${ts.join(", ")}`);
          const f = [...blur, ...glow];
          if (f.length) d.push(`filter: ${f.join(" ")}`);
        }
        return d;
      }

      function buildCSS() {
        // The poly behind the logo — always emitted (this is the main knob now).
        const cell = `:root {\n  --logo-cell-fill: ${hexA(cfg.cellColor, cfg.cellAlpha)};\n}`;
        // Only restyle the wordmark text when asked (the live site uses an
        // image logo, so leave it alone by default).
        if (!cfg.styleWordmark) return cell;
        const d = compute();
        let css = ".brand {\n  " + d.join(";\n  ") + ";\n}";
        if (cfg.sheenOn) css += "\n\n@keyframes brandlabSheen {\n  from { background-position: 160% 0, 0 0; }\n  to { background-position: -60% 0, 0 0; }\n}";
        return css + "\n\n" + cell;
      }

      function injectFrame(css) {
        const fr = document.getElementById("frame");
        if (!fr) return;
        let doc;
        try { doc = fr.contentDocument || (fr.contentWindow && fr.contentWindow.document); } catch { doc = null; }
        if (!doc || !doc.head) return;
        let st = doc.getElementById("brandlab-override");
        if (!st) { st = doc.createElement("style"); st.id = "brandlab-override"; doc.head.appendChild(st); }
        st.textContent = css;
        // Only touch the wordmark when explicitly styling text — the live site
        // uses an <img> logo, and setting textContent would wipe it.
        if (cfg.styleWordmark) {
          const g = GFONT[cfg.font];
          if (g) {
            let fl = doc.getElementById("brandlab-font");
            if (!fl) { fl = doc.createElement("link"); fl.id = "brandlab-font"; fl.rel = "stylesheet"; doc.head.appendChild(fl); }
            const href = `https://fonts.googleapis.com/css2?family=${g}&display=swap`;
            if (fl.getAttribute("href") !== href) fl.setAttribute("href", href);
          }
          const b = doc.querySelector(".brand");
          if (b && cfg.text && b.textContent !== cfg.text) b.textContent = cfg.text;
        }
      }

      function setZoom() {
        const fr = document.getElementById("frame");
        const z = cfg.zoom || 1;
        fr.style.width = 100 / z + "%";
        fr.style.height = 100 / z + "%";
        fr.style.transform = `scale(${z})`;
      }

      function apply() {
        const css = buildCSS();
        document.getElementById("css").value = css;
        injectFrame(css);
        setZoom();
        save();
      }

      function rowHTML(k, label, t, o = {}) {
        if (t === "range")
          return `<div class="row"><label>${label}</label><input type="range" data-k="${k}" min="${o.min}" max="${o.max}" step="${o.step}"><span class="val" data-v="${k}"></span></div>`;
        if (t === "select")
          return `<div class="row"><label>${label}</label><select data-k="${k}">${o.opts.map(([v, n]) => `<option value="${v}">${n}</option>`).join("")}</select><span></span></div>`;
        if (t === "color")
          return `<div class="row"><label>${label}</label><input type="color" data-k="${k}"><span></span></div>`;
        if (t === "text")
          return `<div class="row"><label>${label}</label><input type="text" data-k="${k}"><span></span></div>`;
        if (t === "check")
          return `<div class="row"><label>${label}</label><input type="checkbox" data-k="${k}"><span></span></div>`;
        return "";
      }

      function buildControls() {
        let html = "";
        for (const [group, items] of FIELDS) {
          html += `<details class="grp" open><summary>${group}</summary><div class="fields">`;
          html += items.map(([k, label, t, o]) => rowHTML(k, label, t, o)).join("");
          if (group === "Fill")
            html += `<div id="stopsWrap"><div class="row"><label>Gradient stops</label><span></span><span></span></div><div class="stops" id="stops"></div><button class="mini" id="addStop" type="button">+ Add stop</button></div>`;
          html += `</div></details>`;
        }
        document.getElementById("controls").innerHTML = html;

        // Populate values from cfg.
        document.querySelectorAll("[data-k]").forEach((el) => {
          const k = el.dataset.k;
          if (el.type === "checkbox") el.checked = !!cfg[k];
          else el.value = cfg[k];
          const v = document.querySelector(`[data-v="${k}"]`);
          if (v) v.textContent = fmtVal(k);
          el.addEventListener("input", () => onChange(k, el));
          el.addEventListener("change", () => onChange(k, el));
        });
        renderStops();
        document.getElementById("addStop").addEventListener("click", () => {
          cfg.stops.push({ c: "#000000", p: 100, a: 1 });
          renderStops(); apply();
        });
      }

      function fmtVal(k) {
        const f = FIELDS.flatMap(([, it]) => it).find((x) => x[0] === k);
        const unit = f && f[3] && f[3].unit ? f[3].unit : "";
        return typeof cfg[k] === "number" ? cfg[k] + unit : "";
      }

      function onChange(k, el) {
        if (el.type === "checkbox") cfg[k] = el.checked;
        else if (el.type === "range") cfg[k] = parseFloat(el.value);
        else cfg[k] = el.value;
        const v = document.querySelector(`[data-v="${k}"]`);
        if (v) v.textContent = fmtVal(k);
        apply();
      }

      function renderStops() {
        const wrap = document.getElementById("stops");
        wrap.innerHTML = cfg.stops
          .map((s, i) =>
            `<div class="stop"><input type="color" data-si="${i}" data-sf="c" value="${s.c}"><input type="range" data-si="${i}" data-sf="p" min="0" max="100" step="1" value="${s.p}" title="position ${s.p}%"><input type="range" data-si="${i}" data-sf="a" min="0" max="1" step="0.01" value="${s.a}" title="opacity ${s.a}"><button class="mini" data-del="${i}" type="button">×</button></div>`
          )
          .join("");
        wrap.querySelectorAll("[data-si]").forEach((el) => {
          el.addEventListener("input", () => {
            const i = +el.dataset.si, f = el.dataset.sf;
            cfg.stops[i][f] = f === "c" ? el.value : parseFloat(el.value);
            if (f !== "c") el.title = (f === "p" ? "position " + el.value + "%" : "opacity " + el.value);
            apply();
          });
        });
        wrap.querySelectorAll("[data-del]").forEach((el) => {
          el.addEventListener("click", () => {
            if (cfg.stops.length <= 2) return;
            cfg.stops.splice(+el.dataset.del, 1);
            renderStops(); apply();
          });
        });
      }

      // Output buttons.
      document.getElementById("copyCss").addEventListener("click", (e) => {
        navigator.clipboard.writeText(document.getElementById("css").value);
        e.target.textContent = "Copied!"; setTimeout(() => (e.target.textContent = "Copy CSS"), 1200);
      });
      document.getElementById("copyJson").addEventListener("click", (e) => {
        navigator.clipboard.writeText(JSON.stringify(cfg, null, 2));
        e.target.textContent = "Copied!"; setTimeout(() => (e.target.textContent = "Copy JSON"), 1200);
      });
      document.getElementById("importJson").addEventListener("click", () => {
        try {
          const inc = JSON.parse(document.getElementById("jsonIn").value);
          cfg = Object.assign(structuredClone(DEFAULTS), inc);
          buildControls(); apply();
        } catch (err) { alert("Invalid JSON: " + err.message); }
      });
      document.getElementById("reset").addEventListener("click", () => {
        cfg = structuredClone(DEFAULTS);
        buildControls(); apply();
      });

      // Re-inject on every (re)load of the framed site, e.g. after in-frame nav.
      const frame = document.getElementById("frame");
      frame.addEventListener("load", () => { injectFrame(buildCSS()); setZoom(); });
      document.getElementById("reloadFrame").addEventListener("click", () => {
        try { frame.contentWindow.location.reload(); } catch { frame.src = frame.src; }
      });

      buildControls();
      apply();
    </script>
  </body>
</html>
