# Maintenance-gate secrets for the container (copy to `.env` on the server).
# NEVER commit the real .env — it is gitignored.
#
#   cp .env.example .env   # then set real values on the deploy host
#
# GATE_PIN   : the 6-digit PIN that unlocks the real site (typed on the gate)
# GATE_TOKEN : a long random secret stored in the unlock cookie (nginx checks it)
#              generate with: openssl rand -hex 32

GATE_PIN=000000
GATE_TOKEN=replace-with-a-long-random-secret
